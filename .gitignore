# Flutter / Dart / Firebase .gitignore

# Miscellaneous

*.log
*.tmp
*.swp
.DS_Store
.idea/
.vscode/
*.iml

# Dart / Flutter

.dart_tool/
.packages
.pub-cache/
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies
.metadata

# Generated files

**/generated_plugin_registrant.dart

# Android

android/.gradle/
android/app/build/
android/build/
android/local.properties
android/app/debug/
android/app/profile/
android/app/release/
*.keystore
*.jks

# iOS

ios/Flutter/flutter_export_environment.sh
ios/Pods/
ios/.symlinks/
ios/Runner.xcworkspace/
ios/Runner/GeneratedPluginRegistrant.*
ios/Flutter/Flutter.framework
ios/Flutter/App.framework
ios/ServiceDefinitions.json

# macOS

macos/Flutter/ephemeral/
macos/Pods/

# Linux

linux/flutter/ephemeral/

# Windows

windows/flutter/ephemeral/

# Web

build/web/

# Firebase

# Firebase CLI cache

.firebase/
.firebase/hosting.*

# Firebase config files (be careful — include only if you DON'T want to share them)

# Uncomment if needed:

# android/app/google-services.json

# ios/Runner/GoogleService-Info.plist

# Firestore / Emulator

firestore-debug.log
firestore_export/
firebase-debug.log

# Crashlytics

crashlytics-build.properties

# Environment files

.env
.env.*

# Coverage

coverage/

# Lock files (optional: usually keep pubspec.lock for apps)

# pubspec.lock

# Fastlane

fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Obfuscation

app.*.symbols

# IDE specific

*.ipr
*.iws

# Temporary files

*.bak
*.orig
