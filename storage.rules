rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Charging station photos
    match /charging_stations/{stationId}/{fileName} {
      // Allow authenticated users to upload station photos
      allow write: if request.auth != null 
                   && request.resource.size < 10 * 1024 * 1024  // 10MB limit
                   && request.resource.contentType.matches('image/.*');
      
      // Allow anyone to read station photos (for public viewing)
      allow read: if true;
    }
    
    // Allow authenticated users to upload any file (for future use)
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}

